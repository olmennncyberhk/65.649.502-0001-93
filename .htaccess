<IfModule mod_rewrite.c>
  RewriteEngine On

  # Arquivos reais (js, css, img, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # /install → redireciona para home (página removida do fluxo)
  RewriteRule ^install/?$ index.html [L]

  # Rotas do React Router
  RewriteRule ^(formulario|taxaambiental|permanente|termos|privacidade)(/.*)?$ index.html [L]

  # Qualquer outra rota do app → index.html (evita 404 ao dar F5)
  RewriteRule ^ index.html [L]
</IfModule>
